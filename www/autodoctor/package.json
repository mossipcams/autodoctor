{
  "name": "autodoctor-card",
  "version": "2.32.0",
  "description": "Lovelace card for Autodoctor automation health",
  "type": "module",
  "scripts": {
    "build": "rollup -c --forceExit && cp autodoctor-card.js ../../custom_components/autodoctor/www/",
    "build:minified": "AUTODOCTOR_MINIFY=1 rollup -c --forceExit && cp autodoctor-card.js ../../custom_components/autodoctor/www/",
    "watch": "rollup -c --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint:deps": "dependency-cruiser --config .dependency-cruiser.cjs --output-type err .",
    "lint:deadcode": "knip",
    "lint:duplicates": "jscpd --config .jscpd.json .",
    "quality:code-health": "node ./quality-checks.mjs",
    "format": "prettier --write '*.ts' '*.js' '*.json'",
    "format:check": "prettier --check '*.ts' '*.js' '*.json'"
  },
  "devDependencies": {
    "@rollup/plugin-node-resolve": "^15.2.3",
    "@rollup/plugin-replace": "^6.0.3",
    "@rollup/plugin-terser": "^0.4.4",
    "@rollup/plugin-typescript": "^11.1.6",
    "dependency-cruiser": "^17.3.10",
    "happy-dom": "^20.4.0",
    "jscpd": "^4.0.9",
    "knip": "^6.4.1",
    "lit": "^3.1.0",
    "prettier": "^3.2.0",
    "rollup": "^4.9.0",
    "tdd-guard-vitest": "^0.1.6",
    "typescript": "^5.3.0",
    "vitest": "^4.0.18"
  },
  "dependencies": {
    "custom-card-helpers": "^1.9.0"
  }
}
